# Copy to .env. Pick ONE provider by setting its key. With no key the app runs
# entirely on the rule-based mock (fully demoable, but ignores the real image).

# Option A — Google Gemini (FREE tier, no credit card). Get a key at
# https://aistudio.google.com/apikey  → enables real image analysis for free.
GEMINI_API_KEY=
# TGA_GEMINI_MODEL=gemini-2.0-flash

# Option B — Anthropic Claude (paid). https://platform.claude.com
ANTHROPIC_API_KEY=
# TGA_MODEL=claude-opus-4-8

# Force a provider explicitly: gemini | anthropic | mock
# TGA_PROVIDER=gemini
# Force mock even when a key is present:
# TGA_FORCE_MOCK=1
